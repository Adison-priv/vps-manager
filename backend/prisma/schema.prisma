generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Server {

  id         String   @id @default(cuid())

  name       String

  host       String
  port       Int

  username   String

  privateKey String?

  createdAt  DateTime @default(now())
}