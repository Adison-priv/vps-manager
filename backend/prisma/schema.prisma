generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Server {

  id String @id @default(cuid())

  hostname String

  host String
  port Int

  username String

  os String?

  region String?

  cpuCores Int?

  ramTotal Int?

  diskTotal String?

  status String?

  privateKey String?

  createdAt DateTime @default(now())
}